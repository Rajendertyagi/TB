<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1180"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#0C0D0F">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="4"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border
        Background="#0C0D0F"
        BorderBrush="#18191C"
        BorderThickness="1"
        CornerRadius="7"
        SnapsToDevicePixels="True">

        <Grid>

            <Grid.RowDefinitions>

                <!-- HELIUM TAB STRIP -->
                <RowDefinition Height="30"/>

                <!-- FLOATING OMNIBOX -->
                <RowDefinition Height="30"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

                <!-- STATUS -->
                <RowDefinition Height="18"/>

            </Grid.RowDefinitions>

            <!-- TITLEBAR -->

            <ui:BrowserTitleBar
                x:Name="BrowserTitleBar"
                Grid.Row="0"/>

            <!-- NAVIGATION -->

            <ui:NavigationBar
                x:Name="NavigationBar"
                Grid.Row="1"/>

            <!-- WEBVIEW -->

            <Border
                Grid.Row="2"
                Background="#0C0D0F"
                ClipToBounds="True">

                <ui:WebViewContainer
                    x:Name="WebViewContainer"/>

            </Border>

            <!-- STATUSBAR -->

            <ui:StatusBar
                x:Name="StatusBar"
                Grid.Row="3"/>

        </Grid>

    </Border>

</Window>
