<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1200"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#0D0D0E">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="40"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border
        Margin="0"
        Background="#0D0D0E"
        BorderBrush="#202126"
        BorderThickness="1"
        CornerRadius="12"
        SnapsToDevicePixels="True">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- TITLEBAR -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- DRAG REGION -->

                <Border
                    Grid.Column="0"
                    Background="Transparent"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- TITLEBAR CONTROL -->

                <ui:BrowserTitleBar
                    x:Name="BrowserTitleBar"
                    Grid.ColumnSpan="2"/>

            </Grid>

            <!-- NAVIGATION -->

            <ui:NavigationBar
                x:Name="NavigationBar"
                Grid.Row="1"/>

            <!-- WEBVIEW -->

            <ui:WebViewContainer
                x:Name="WebViewContainer"
                Grid.Row="2"/>

            <!-- STATUSBAR -->

            <ui:StatusBar
                Grid.Row="3"/>

        </Grid>

    </Border>

</Window>
