<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1200"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#0D0D0E">

    <Border
        BorderBrush="#202126"
        BorderThickness="1"
        CornerRadius="10"
        Background="#0D0D0E">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="74"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="24"/>

            </Grid.RowDefinitions>

            <!-- TOP CHROME -->

            <Border
                Grid.Row="0"
                Background="#111214"
                BorderBrush="#1E1F22"
                BorderThickness="0,0,0,1">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="34"/>

                        <RowDefinition Height="40"/>

                    </Grid.RowDefinitions>

                    <!-- TAB STRIP -->

                    <Grid
                        Grid.Row="0"
                        Background="#111214"
                        MouseLeftButtonDown="OnWindowDrag">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*"/>

                            <ColumnDefinition Width="Auto"/>

                        </Grid.ColumnDefinitions>

                        <!-- LEFT -->

                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">

                            <!-- ACTIVE TAB -->

                            <Border
                                Width="240"
                                Height="28"
                                Background="#1C1D21"
                                CornerRadius="8,8,0,0"
                                Margin="0,0,4,0"
                                BorderBrush="#2C7DFF"
                                BorderThickness="1">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="Auto"/>

                                        <ColumnDefinition Width="*"/>

                                        <ColumnDefinition Width="Auto"/>

                                    </Grid.ColumnDefinitions>

                                    <!-- FAVICON -->

                                    <Border
                                        Width="14"
                                        Height="14"
                                        Margin="10,0,8,0"
                                        VerticalAlignment="Center"
                                        CornerRadius="7"
                                        Background="#4285F4"/>

                                    <!-- TITLE -->

                                    <TextBlock
                                        x:Name="PageTitleText"
                                        Grid.Column="1"
                                        Text="New Tab"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        TextTrimming="CharacterEllipsis"/>

                                    <!-- CLOSE -->

                                    <Border
                                        Grid.Column="2"
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,8,0"
                                        CornerRadius="4"
                                        Background="Transparent">

                                        <TextBlock
                                            Text="✕"
                                            FontSize="10"
                                            Foreground="#A8A8A8"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                    </Border>

                                </Grid>

                            </Border>

                            <!-- ADD TAB -->

                            <Button
                                Width="28"
                                Height="28"
                                Click="OnAddTabClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Width="22"
                                    Height="22"
                                    CornerRadius="6"
                                    Background="#191A1D">

                                    <TextBlock
                                        Text="+"
                                        FontSize="15"
                                        Foreground="#D0D0D0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                        </StackPanel>

                        <!-- WINDOW BUTTONS -->

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">

                            <!-- MIN -->

                            <Button
                                Width="46"
                                Height="30"
                                Click="OnMinimizeClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Background="Transparent"
                                    CornerRadius="6">

                                    <TextBlock
                                        Text="—"
                                        FontSize="11"
                                        Foreground="#D8D8D8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                            <!-- MAX -->

                            <Button
                                Width="46"
                                Height="30"
                                Click="OnMaximizeClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Background="Transparent"
                                    CornerRadius="6">

                                    <TextBlock
                                        Text="▢"
                                        FontSize="10"
                                        Foreground="#D8D8D8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                            <!-- CLOSE -->

                            <Button
                                Width="46"
                                Height="30"
                                Click="OnCloseClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Background="Transparent"
                                    CornerRadius="6">

                                    <TextBlock
                                        Text="✕"
                                        FontSize="11"
                                        Foreground="#D8D8D8"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                        </StackPanel>

                    </Grid>

                    <!-- NAVBAR -->

                    <Grid
                        Grid.Row="1"
                        Margin="10,0,10,6">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <!-- NAV BUTTONS -->

                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">

                            <Button
                                Width="30"
                                Height="30"
                                Click="OnBackClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Width="26"
                                    Height="26"
                                    CornerRadius="13"
                                    Background="#18191C">

                                    <TextBlock
                                        Text="←"
                                        FontSize="12"
                                        Foreground="#E1E1E1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                            <Button
                                Width="30"
                                Height="30"
                                Click="OnForwardClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Width="26"
                                    Height="26"
                                    CornerRadius="13"
                                    Background="#18191C">

                                    <TextBlock
                                        Text="→"
                                        FontSize="12"
                                        Foreground="#E1E1E1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                            <Button
                                Width="30"
                                Height="30"
                                Click="OnRefreshClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Width="26"
                                    Height="26"
                                    CornerRadius="13"
                                    Background="#18191C">

                                    <TextBlock
                                        Text="↻"
                                        FontSize="12"
                                        Foreground="#E1E1E1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                            <Button
                                Width="30"
                                Height="30"
                                Click="OnHomeClicked"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">

                                <Border
                                    Width="26"
                                    Height="26"
                                    CornerRadius="13"
                                    Background="#18191C">

                                    <TextBlock
                                        Text="⌂"
                                        FontSize="12"
                                        Foreground="#E1E1E1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>

                                </Border>

                            </Button>

                        </StackPanel>

                        <!-- OMNIBOX -->

                        <Border
                            Grid.Column="1"
                            Height="34"
                            CornerRadius="17"
                            Background="#17181B"
                            BorderBrush="#2B2D33"
                            BorderThickness="1">

                            <Grid>

                                <Grid.ColumnDefinitions>

                                    <ColumnDefinition Width="Auto"/>

                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="Auto"/>

                                </Grid.ColumnDefinitions>

                                <!-- SECURITY -->

                                <TextBlock
                                    Grid.Column="0"
                                    Text="🔒"
                                    Margin="12,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="#9EA3AA"
                                    FontSize="11"/>

                                <!-- ADDRESS -->

                                <TextBox
                                    x:Name="AddressBar"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontSize="13"
                                    VerticalContentAlignment="Center"
                                    KeyDown="OnAddressBarKeyDown"/>

                                <!-- LOADING DOT -->

                                <Border
                                    Grid.Column="2"
                                    Width="10"
                                    Height="10"
                                    Margin="0,0,14,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="5"
                                    Background="#2C7DFF"/>

                            </Grid>

                        </Border>

                    </Grid>

                </Grid>

            </Border>

            <!-- LOADING BAR -->

            <ProgressBar
                x:Name="LoadingBar"
                Grid.Row="0"
                Height="2"
                VerticalAlignment="Bottom"
                Foreground="#2C7DFF"
                Background="Transparent"
                Visibility="Collapsed"
                IsIndeterminate="True"/>

            <!-- WEBVIEW -->

            <Border
                Grid.Row="1"
                Margin="8,8,8,4"
                CornerRadius="10"
                Background="#111111"
                BorderBrush="#1D1F25"
                BorderThickness="1"
                ClipToBounds="True">

                <Grid>

                    <!-- CLIPPING LAYER -->

                    <Border
                        CornerRadius="10"
                        Background="#111111"
                        ClipToBounds="True">

                        <webview:WebView2
                            x:Name="BrowserHost"
                            DefaultBackgroundColor="Transparent"/>

                    </Border>

                </Grid>

            </Border>

            <!-- STATUSBAR -->

            <Border
                Grid.Row="2"
                Background="#101113"
                BorderBrush="#1E1F22"
                BorderThickness="0,1,0,0">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="StatusText"
                        Grid.Column="0"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#8F9093"
                        Text="Ready"/>

                    <TextBlock
                        Grid.Column="1"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#8F9093"
                        Text="RTBrowser"/>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>
