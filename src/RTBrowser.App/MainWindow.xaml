<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1200"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource BackgroundPrimaryBrush}">

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="30" />

            <RowDefinition Height="30" />

            <RowDefinition Height="38" />

            <RowDefinition Height="*" />

            <RowDefinition Height="22" />

        </Grid.RowDefinitions>

        <!-- TITLE BAR -->

        <controls:BrowserTitleBar
            Grid.Row="0" />

        <!-- TAB BAR -->

        <controls:CompactTabView
            Grid.Row="1" />

        <!-- OMNIBOX -->

        <Border
            Grid.Row="2"
            Background="{StaticResource BackgroundPrimaryBrush}"
            Padding="8,4">

            <controls:CompactOmnibox
                x:Name="Omnibox" />

        </Border>

        <!-- WEBVIEW -->

        <Border
            Grid.Row="3"
            Margin="8"
            CornerRadius="8"
            ClipToBounds="True"
            Background="#111111">

            <webview:WebView2
                x:Name="BrowserView"
                DefaultBackgroundColor="Transparent" />

        </Border>

        <!-- STATUS BAR -->

        <controls:StatusBar
            Grid.Row="4" />

    </Grid>

</Window>
