<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1180"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#0D0D0E">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border
        Background="#0D0D0E"
        BorderBrush="#1B1C1F"
        BorderThickness="1"
        CornerRadius="8"
        SnapsToDevicePixels="True">

        <Grid>

            <Grid.RowDefinitions>

                <!-- HELIUM TAB STRIP -->
                <RowDefinition Height="30"/>

                <!-- FLOATING OMNIBOX -->
                <RowDefinition Height="30"/>

                <!-- CONTENT -->
                <RowDefinition Height="*"/>

                <!-- STATUS -->
                <RowDefinition Height="18"/>

            </Grid.RowDefinitions>

            <!-- TAB STRIP -->

            <Grid
                Grid.Row="0"
                Background="#101113">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- DRAG REGION -->

                <Border
                    Grid.Column="0"
                    Background="Transparent"
                    shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- TITLEBAR -->

                <ui:BrowserTitleBar
                    x:Name="BrowserTitleBar"
                    Grid.ColumnSpan="2"/>

            </Grid>

            <!-- NAVIGATION -->

            <ui:NavigationBar
                x:Name="NavigationBar"
                Grid.Row="1"/>

            <!-- WEBVIEW -->

            <Border
                Grid.Row="2"
                Margin="0"
                Background="#0D0D0E">

                <ui:WebViewContainer
                    x:Name="WebViewContainer"/>

            </Border>

            <!-- STATUSBAR -->

            <ui:StatusBar
                Grid.Row="3"/>

        </Grid>

    </Border>

</Window>
