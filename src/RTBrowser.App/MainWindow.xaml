<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    mc:Ignorable="d"

    Title="RTBrowser"
    Width="1600"
    Height="900"

    MinWidth="1200"
    MinHeight="700"

    Background="{StaticResource BackgroundPrimaryBrush}"

    WindowStyle="None"
    ResizeMode="CanResize"
    AllowsTransparency="False">

    <Grid Background="{StaticResource BackgroundPrimaryBrush}">

        <Grid.RowDefinitions>

            <!-- TITLEBAR -->
            <RowDefinition Height="30"/>

            <!-- TAB STRIP -->
            <RowDefinition Height="30"/>

            <!-- WEB CONTENT -->
            <RowDefinition Height="*"/>

            <!-- STATUS BAR -->
            <RowDefinition Height="22"/>

        </Grid.RowDefinitions>

        <!-- ========================================= -->
        <!-- TITLE BAR -->
        <!-- ========================================= -->

        <controls:BrowserTitleBar
            Grid.Row="0" />

        <!-- ========================================= -->
        <!-- TAB VIEW -->
        <!-- ========================================= -->

        <controls:CompactTabView
            Grid.Row="1" />

        <!-- ========================================= -->
        <!-- MAIN CONTENT -->
        <!-- ========================================= -->

        <Grid
            Grid.Row="2"
            Background="{StaticResource BackgroundSecondaryBrush}">

            <!-- PLACEHOLDER -->
            <!-- WEBVIEW2 COMES HERE LATER -->

            <Border
                Margin="8"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="{StaticResource RadiusLarge}">

                <Grid>

                    <TextBlock
                        Text="RTBrowser Runtime Placeholder"
                        Style="{StaticResource ToolbarTextStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}" />

                </Grid>

            </Border>

        </Grid>

        <!-- ========================================= -->
        <!-- STATUS BAR -->
        <!-- ========================================= -->

        <controls:StatusBar
            Grid.Row="3" />

    </Grid>

</Window>
