<Window
    x:Class="RTBrowser.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:RTBrowser.UI.Controls;assembly=RTBrowser.UI"
    Title="RTBrowser"
    Width="1720"
    Height="920"
    MinWidth="1200"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="#0D0D0E">

    <Border
        BorderBrush="#202126"
        BorderThickness="1"
        CornerRadius="10"
        Background="#0D0D0E">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="34"/>

                <RowDefinition Height="40"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="24"/>

            </Grid.RowDefinitions>

            <!-- TITLEBAR -->

            <ui:BrowserTitleBar
                Grid.Row="0"/>

            <!-- NAVIGATION -->

            <ui:NavigationBar
                Grid.Row="1"/>

            <!-- WEBVIEW -->

            <ui:WebViewContainer
                x:Name="WebViewContainer"
                Grid.Row="2"/>

            <!-- STATUSBAR -->

            <ui:StatusBar
                Grid.Row="3"/>

        </Grid>

    </Border>

</Window>
