<Application
    x:Class="RTBrowser.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ShutdownMode="OnMainWindowClose">

    <Application.Resources>

        <SolidColorBrush
            x:Key="WindowBackgroundBrush"
            Color="#0C0D0F"/>

        <SolidColorBrush
            x:Key="ChromeBackgroundBrush"
            Color="#101113"/>

        <SolidColorBrush
            x:Key="ChromeBorderBrush"
            Color="#1A1B1E"/>

        <SolidColorBrush
            x:Key="ControlBackgroundBrush"
            Color="#17181B"/>

        <SolidColorBrush
            x:Key="ControlBorderBrush"
            Color="#24262B"/>

        <SolidColorBrush
            x:Key="AccentBrush"
            Color="#4C8DFF"/>

        <SolidColorBrush
            x:Key="PrimaryTextBrush"
            Color="#ECECEC"/>

        <SolidColorBrush
            x:Key="SecondaryTextBrush"
            Color="#9AA0A8"/>

        <SolidColorBrush
            x:Key="MutedTextBrush"
            Color="#7E848D"/>

    </Application.Resources>

</Application>
