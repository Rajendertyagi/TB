<Application
    x:Class="RTBrowser.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    StartupUri="MainWindow.xaml">

    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary
                    Source="/RTBrowser.UI;component/Themes/Colors.xaml"/>

                <ResourceDictionary
                    Source="/RTBrowser.UI;component/Themes/Typography.xaml"/>

                <ResourceDictionary
                    Source="/RTBrowser.UI;component/Themes/Spacing.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>
