<UserControl
    x:Class="RTBrowser.UI.Controls.NavigationBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="44">

    <Border
        Background="#111214"
        BorderBrush="#1E1F22"
        BorderThickness="0,0,0,1">

        <Grid Margin="10,4,10,4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT NAV -->

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                <Button
                    x:Name="BackButton"
                    Width="30"
                    Height="30"
                    Margin="0,0,4,0"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="←"
                        FontSize="12"
                        Foreground="#D0D0D0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <Button
                    x:Name="ForwardButton"
                    Width="30"
                    Height="30"
                    Margin="0,0,4,0"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="→"
                        FontSize="12"
                        Foreground="#D0D0D0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <Button
                    x:Name="RefreshButton"
                    Width="30"
                    Height="30"
                    Margin="0,0,8,0"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="↻"
                        FontSize="12"
                        Foreground="#D0D0D0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

            </StackPanel>

            <!-- OMNIBOX -->

            <Border
                Grid.Column="1"
                Height="34"
                Background="#191B1F"
                BorderBrush="#2A2D32"
                BorderThickness="1"
                CornerRadius="17"
                VerticalAlignment="Center">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LOCK -->

                    <TextBlock
                        Grid.Column="0"
                        Text="🔒"
                        FontSize="11"
                        Foreground="#9FA3AA"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                    <!-- URL BOX -->

                    <TextBox
                        x:Name="AddressBar"
                        Grid.Column="1"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="13"
                        CaretBrush="White"
                        VerticalContentAlignment="Center"
                        Padding="0,0,12,0"/>

                </Grid>

            </Border>

            <!-- RIGHT -->

            <Ellipse
                Grid.Column="2"
                Width="10"
                Height="10"
                Margin="12,0,0,0"
                Fill="#2C7DFF"
                VerticalAlignment="Center"/>

        </Grid>

    </Border>

</UserControl>
