<UserControl
    x:Class="RTBrowser.UI.Controls.NavigationBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="40">

    <Border
        Background="{StaticResource BackgroundPrimaryBrush}"
        BorderBrush="#1E1F22"
        BorderThickness="0,0,0,1">

        <Grid Margin="10,0,10,6">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <!-- NAV BUTTONS -->

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,8,0">

                <!-- BACK -->

                <Button
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <Border
                        Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="#18191C">

                        <TextBlock
                            Text="←"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

                <!-- FORWARD -->

                <Button
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <Border
                        Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="#18191C">

                        <TextBlock
                            Text="→"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

                <!-- REFRESH -->

                <Button
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <Border
                        Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="#18191C">

                        <TextBlock
                            Text="↻"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

                <!-- HOME -->

                <Button
                    Width="30"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <Border
                        Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="#18191C">

                        <TextBlock
                            Text="⌂"
                            FontSize="12"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

            </StackPanel>

            <!-- OMNIBOX -->

            <Border
                Grid.Column="1"
                Height="34"
                CornerRadius="17"
                Background="#17181B"
                BorderBrush="#2B2D33"
                BorderThickness="1">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"/>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <!-- SECURITY -->

                    <TextBlock
                        Grid.Column="0"
                        Text="🔒"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="#9EA3AA"
                        FontSize="11"/>

                    <!-- ADDRESS -->

                    <TextBox
                        x:Name="AddressBar"
                        Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="13"
                        VerticalContentAlignment="Center"/>

                    <!-- LOADING DOT -->

                    <Border
                        Grid.Column="2"
                        Width="10"
                        Height="10"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        CornerRadius="5"
                        Background="#2C7DFF"/>

                </Grid>

            </Border>

        </Grid>

    </Border>

</UserControl>
