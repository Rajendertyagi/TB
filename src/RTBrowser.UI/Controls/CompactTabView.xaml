<UserControl
    x:Class="RTBrowser.UI.Controls.CompactTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="{StaticResource TabBarHeight}">

    <Border
        Background="{StaticResource BackgroundPrimaryBrush}">

        <Grid Height="{StaticResource TabBarHeight}">

            <ScrollViewer
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Disabled">

                <StackPanel
                    Orientation="Horizontal"
                    Margin="8,0">

                    <!-- ACTIVE TAB -->

                    <Border
                        Width="180"
                        Height="26"
                        Margin="0,0,4,0"
                        Background="{StaticResource ActiveBrush}"
                        CornerRadius="{StaticResource RadiusMedium}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Text=""
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Margin="10,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock
                                Grid.Column="1"
                                Text="TradingView"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                FontFamily="{StaticResource AppFontFamily}"
                                FontSize="{StaticResource FontTabs}"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <Button
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                Margin="4,0,6,0"
                                Background="Transparent"
                                BorderThickness="0">

                                <TextBlock
                                    Text=""
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="10"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center" />

                            </Button>

                        </Grid>

                    </Border>

                    <!-- INACTIVE TAB -->

                    <Border
                        Width="160"
                        Height="26"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        CornerRadius="{StaticResource RadiusMedium}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                Text=""
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Margin="10,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}" />

                            <TextBlock
                                Grid.Column="1"
                                Text="Google"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                FontFamily="{StaticResource AppFontFamily}"
                                FontSize="{StaticResource FontTabs}"
                                Foreground="{StaticResource TextSecondaryBrush}" />

                        </Grid>

                    </Border>

                    <!-- ADD TAB -->

                    <Button
                        Width="28"
                        Height="26"
                        Background="Transparent"
                        BorderThickness="0">

                        <TextBlock
                            Text=""
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center" />

                    </Button>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Border>

</UserControl>
