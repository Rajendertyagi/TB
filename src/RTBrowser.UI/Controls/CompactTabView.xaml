<UserControl
    x:Class="RTBrowser.UI.Controls.CompactTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="{StaticResource TabBarHeight}">

    <Border
        Background="{StaticResource BackgroundPrimaryBrush}">

        <Grid Height="{StaticResource TabBarHeight}">

            <!-- ========================================= -->
            <!-- TAB STRIP -->
            <!-- ========================================= -->

            <ScrollViewer
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Disabled"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">

                <StackPanel
                    Orientation="Horizontal"
                    Margin="{StaticResource Spacing8},0">

                    <!-- ========================================= -->
                    <!-- ACTIVE TAB -->
                    <!-- ========================================= -->

                    <Border
                        Width="180"
                        Height="26"
                        Margin="0,0,4,0"
                        Background="{StaticResource ActiveBrush}"
                        CornerRadius="{StaticResource RadiusMedium}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- FAVICON -->

                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE774;"
                                FontSize="12"
                                Margin="10,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <!-- TITLE -->

                            <TextBlock
                                Grid.Column="1"
                                Text="TradingView"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                FontFamily="{StaticResource AppFontFamily}"
                                FontSize="{StaticResource FontTabs}"
                                Foreground="{StaticResource TextPrimaryBrush}" />

                            <!-- CLOSE -->

                            <Button
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                Margin="4,0,6,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                VerticalAlignment="Center">

                                <FontIcon
                                    Glyph="&#xE711;"
                                    FontSize="{StaticResource TabCloseIconSize}"
                                    Foreground="{StaticResource TextSecondaryBrush}" />

                            </Button>

                        </Grid>

                    </Border>

                    <!-- ========================================= -->
                    <!-- INACTIVE TAB -->
                    <!-- ========================================= -->

                    <Border
                        Width="160"
                        Height="26"
                        Margin="0,0,4,0"
                        Background="Transparent"
                        CornerRadius="{StaticResource RadiusMedium}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- FAVICON -->

                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE774;"
                                FontSize="12"
                                Margin="10,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextSecondaryBrush}" />

                            <!-- TITLE -->

                            <TextBlock
                                Grid.Column="1"
                                Text="Google"
                                VerticalAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                FontFamily="{StaticResource AppFontFamily}"
                                FontSize="{StaticResource FontTabs}"
                                Foreground="{StaticResource TextSecondaryBrush}" />

                        </Grid>

                    </Border>

                    <!-- ========================================= -->
                    <!-- ADD TAB BUTTON -->
                    <!-- ========================================= -->

                    <Button
                        Width="28"
                        Height="26"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">

                        <FontIcon
                            Glyph="&#xE710;"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}" />

                    </Button>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Border>

</UserControl>
