<UserControl
    x:Class="RTBrowser.UI.Controls.WebViewContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid Background="#0D0D0E">

        <Border
            Margin="8,8,8,6"
            Background="#111214"
            BorderBrush="#23252B"
            BorderThickness="1"
            CornerRadius="12">

            <Grid ClipToBounds="True">

                <Border
                    Margin="0"
                    Background="#111214"
                    CornerRadius="12"/>

                <webview:WebView2
                    x:Name="BrowserHost"
                    Margin="1"
                    DefaultBackgroundColor="Transparent"/>

            </Grid>

        </Border>

    </Grid>

</UserControl>
