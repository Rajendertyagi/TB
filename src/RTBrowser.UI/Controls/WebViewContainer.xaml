<UserControl
    x:Class="RTBrowser.UI.Controls.WebViewContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:webview="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Border
        Margin="8,8,8,4"
        CornerRadius="10"
        Background="#111111"
        BorderBrush="#1D1F25"
        BorderThickness="1"
        ClipToBounds="True">

        <Grid>

            <Border
                CornerRadius="10"
                Background="#111111"
                ClipToBounds="True">

                <webview:WebView2
                    x:Name="BrowserHost"
                    DefaultBackgroundColor="Transparent" />

            </Border>

        </Grid>

    </Border>

</UserControl>
