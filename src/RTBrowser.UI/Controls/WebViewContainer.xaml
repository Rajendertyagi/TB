<UserControl
    x:Class="RTBrowser.UI.Controls.WebViewContainer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        Background="#0C0D0F"
        ClipToBounds="True">

        <Border
            Margin="0"
            Background="#0C0D0F"
            BorderBrush="#141518"
            BorderThickness="0">

            <Grid
                x:Name="ContentHost"
                ClipToBounds="True"
                SnapsToDevicePixels="True"/>

        </Border>

    </Grid>

</UserControl>
