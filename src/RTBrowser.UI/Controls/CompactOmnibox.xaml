<UserControl
    x:Class="RTBrowser.UI.Controls.CompactOmnibox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="{StaticResource OmniboxHeight}">

    <Border
        Height="{StaticResource OmniboxHeight}"
        Background="{StaticResource SurfaceBrush}"
        CornerRadius="{StaticResource RadiusLarge}"
        Padding="10,0">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================= -->
            <!-- SEARCH ICON -->
            <!-- ========================================= -->

            <FontIcon
                Grid.Column="0"
                Glyph="&#xE721;"
                FontSize="12"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Foreground="{StaticResource TextSecondaryBrush}" />

            <!-- ========================================= -->
            <!-- ADDRESS / SEARCH -->
            <!-- ========================================= -->

            <TextBox
                Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                VerticalAlignment="Center"
                FontFamily="{StaticResource AppFontFamily}"
                FontSize="{StaticResource FontToolbar}"
                Foreground="{StaticResource TextPrimaryBrush}"
                PlaceholderText="Search or enter address"
                Text="tradingview.com" />

            <!-- ========================================= -->
            <!-- SECURITY / STATUS -->
            <!-- ========================================= -->

            <FontIcon
                Grid.Column="2"
                Glyph="&#xE72E;"
                FontSize="12"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Foreground="{StaticResource TextSecondaryBrush}" />

        </Grid>

    </Border>

</UserControl>
