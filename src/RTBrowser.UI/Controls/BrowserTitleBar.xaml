<UserControl
    x:Class="RTBrowser.UI.Controls.BrowserTitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="{StaticResource TabBarHeight}">

    <Border
        Background="{StaticResource BackgroundPrimaryBrush}">

        <Grid Height="{StaticResource TabBarHeight}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================= -->
            <!-- LEFT NAVIGATION -->
            <!-- ========================================= -->

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="{StaticResource Spacing8},0">

                <!-- HOME -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,2,0">

                    <FontIcon
                        Glyph="&#xE80F;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- BACK -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,2,0">

                    <FontIcon
                        Glyph="&#xE72B;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- FORWARD -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,2,0">

                    <FontIcon
                        Glyph="&#xE72A;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- REFRESH -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">

                    <FontIcon
                        Glyph="&#xE72C;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

            </StackPanel>

            <!-- ========================================= -->
            <!-- OMNIBOX -->
            <!-- ========================================= -->

            <Border
                Grid.Column="1"
                Height="{StaticResource OmniboxHeight}"
                Margin="{StaticResource Spacing8},0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="{StaticResource RadiusLarge}"
                VerticalAlignment="Center">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SEARCH ICON -->

                    <FontIcon
                        Grid.Column="0"
                        Glyph="&#xE721;"
                        FontSize="12"
                        Margin="10,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}" />

                    <!-- ADDRESS TEXT -->

                    <TextBlock
                        Grid.Column="1"
                        Text="Search or enter address"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource AppFontFamily}"
                        FontSize="{StaticResource FontToolbar}"
                        Foreground="{StaticResource TextSecondaryBrush}" />

                </Grid>

            </Border>

            <!-- ========================================= -->
            <!-- RIGHT ACTIONS -->
            <!-- ========================================= -->

            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,{StaticResource Spacing8},0">

                <!-- TILES -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,2,0">

                    <FontIcon
                        Glyph="&#xECA5;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- DOWNLOADS -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0,0,2,0">

                    <FontIcon
                        Glyph="&#xE896;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

                <!-- MENU -->

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">

                    <FontIcon
                        Glyph="&#xE712;"
                        FontSize="{StaticResource ToolbarIconSize}"
                        Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
