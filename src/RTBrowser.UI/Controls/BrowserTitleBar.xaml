<UserControl
    x:Class="RTBrowser.UI.Controls.BrowserTitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="30">

    <UserControl.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.82"/>
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.58"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Border
        Background="#101113"
        BorderBrush="#1A1B1E"
        BorderThickness="0,0,0,1"
        MouseLeftButtonDown="OnDragWindow">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- LEFT -->

            <DockPanel
                Grid.Column="0"
                LastChildFill="False"
                VerticalAlignment="Center"
                Margin="8,0,0,0">

                <!-- TABS -->

                <ScrollViewer
                    VerticalScrollBarVisibility="Disabled"
                    HorizontalScrollBarVisibility="Hidden"
                    CanContentScroll="False"
                    Focusable="False">

                    <StackPanel
                        x:Name="TabsHost"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"/>

                </ScrollViewer>

                <!-- NEW TAB -->

                <Button
                    x:Name="NewTabButton"
                    Width="20"
                    Height="20"
                    Margin="6,0,0,0"
                    Click="OnNewTab"
                    DockPanel.Dock="Right">

                    <Border
                        Width="16"
                        Height="16"
                        CornerRadius="4"
                        Background="#16171A">

                        <TextBlock
                            Text="+"
                            FontSize="10"
                            Foreground="#CFCFCF"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

            </DockPanel>

            <!-- WINDOW CONTROLS -->

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,3,0">

                <!-- MINIMIZE -->

                <Button
                    Width="30"
                    Height="22"
                    Click="OnMinimize">

                    <TextBlock
                        Text="—"
                        FontSize="9"
                        Foreground="#A6ABB3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <!-- MAXIMIZE -->

                <Button
                    Width="30"
                    Height="22"
                    Click="OnMaximize">

                    <TextBlock
                        Text="▢"
                        FontSize="8"
                        Foreground="#A6ABB3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <!-- CLOSE -->

                <Button
                    Width="30"
                    Height="22"
                    Click="OnClose">

                    <TextBlock
                        Text="✕"
                        FontSize="9"
                        Foreground="#A6ABB3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
