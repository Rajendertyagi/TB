<UserControl
    x:Class="RTBrowser.UI.Controls.BrowserTitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="34">

    <Border
        Background="#111214"
        BorderBrush="#1E1F22"
        BorderThickness="0,0,0,1">

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*" />

                <ColumnDefinition Width="Auto" />

            </Grid.ColumnDefinitions>

            <!-- ACTIVE TAB -->

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="8,0,0,0">

                <Border
                    Width="240"
                    Height="28"
                    Background="#1C1D21"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#2C7DFF"
                    BorderThickness="1">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                            <ColumnDefinition Width="Auto"/>

                        </Grid.ColumnDefinitions>

                        <Border
                            Width="14"
                            Height="14"
                            Margin="10,0,8,0"
                            VerticalAlignment="Center"
                            CornerRadius="7"
                            Background="#4285F4"/>

                        <TextBlock
                            Grid.Column="1"
                            Text="New Tab"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            TextTrimming="CharacterEllipsis"/>

                        <Border
                            Grid.Column="2"
                            Width="18"
                            Height="18"
                            Margin="0,0,8,0"
                            CornerRadius="4">

                            <TextBlock
                                Text="✕"
                                FontSize="10"
                                Foreground="#A8A8A8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                    </Grid>

                </Border>

                <Button
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0">

                    <Border
                        Width="22"
                        Height="22"
                        CornerRadius="6"
                        Background="#191A1D">

                        <TextBlock
                            Text="+"
                            FontSize="15"
                            Foreground="#D0D0D0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                </Button>

            </StackPanel>

            <!-- WINDOW BUTTONS -->

            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,4,0">

                <Button
                    Width="46"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="—"
                        FontSize="11"
                        Foreground="#D8D8D8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <Button
                    Width="46"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="▢"
                        FontSize="10"
                        Foreground="#D8D8D8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

                <Button
                    Width="46"
                    Height="30"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="✕"
                        FontSize="11"
                        Foreground="#D8D8D8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
