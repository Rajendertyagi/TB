<UserControl
    x:Class="RTBrowser.UI.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="{StaticResource StatusBarHeight}">

    <Border
        Background="{StaticResource BackgroundPrimaryBrush}">

        <Grid Height="{StaticResource StatusBarHeight}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->

            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="8,0">

                <Button
                    Width="22"
                    Height="22"
                    Margin="0,0,4,0"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text=""
                        FontFamily="Segoe Fluent Icons"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />

                </Button>

                <Button
                    Width="22"
                    Height="22"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text=""
                        FontFamily="Segoe Fluent Icons"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />

                </Button>

            </StackPanel>

            <!-- RIGHT -->

            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,8,0">

                <Button
                    Height="22"
                    Margin="0,0,4,0"
                    Padding="6,0"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text="100%"
                        FontFamily="{StaticResource AppFontFamily}"
                        FontSize="{StaticResource FontStatus}"
                        Foreground="{StaticResource TextSecondaryBrush}" />

                </Button>

                <Button
                    Width="22"
                    Height="22"
                    Background="Transparent"
                    BorderThickness="0">

                    <TextBlock
                        Text=""
                        FontFamily="Segoe Fluent Icons"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />

                </Button>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
