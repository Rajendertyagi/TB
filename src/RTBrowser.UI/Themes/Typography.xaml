<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- FONT FAMILY -->

    <FontFamily x:Key="AppFontFamily">
        Segoe UI Variable
    </FontFamily>

    <!-- FONT SIZES -->

    <sys:Double x:Key="FontTabs">
        12.5
    </sys:Double>

    <sys:Double x:Key="FontToolbar">
        12
    </sys:Double>

    <sys:Double x:Key="FontStatus">
        11
    </sys:Double>

    <sys:Double x:Key="FontMenu">
        12
    </sys:Double>

    <sys:Double x:Key="FontSettings">
        13
    </sys:Double>

</ResourceDictionary>
