<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========================================= -->
    <!-- HEIGHTS -->
    <!-- ========================================= -->

    <sys:Double x:Key="TitleBarHeight">
        30
    </sys:Double>

    <sys:Double x:Key="TabBarHeight">
        30
    </sys:Double>

    <sys:Double x:Key="OmniboxHeight">
        32
    </sys:Double>

    <sys:Double x:Key="StatusBarHeight">
        22
    </sys:Double>

    <!-- ========================================= -->
    <!-- ICON SIZES -->
    <!-- ========================================= -->

    <sys:Double x:Key="ToolbarIconSize">
        12
    </sys:Double>

    <sys:Double x:Key="StatusIconSize">
        11
    </sys:Double>

    <sys:Double x:Key="TabCloseIconSize">
        10
    </sys:Double>

    <!-- ========================================= -->
    <!-- TAB SYSTEM -->
    <!-- ========================================= -->

    <sys:Double x:Key="MinimumTabWidth">
        110
    </sys:Double>

    <sys:Double x:Key="PreferredTabWidth">
        160
    </sys:Double>

    <sys:Double x:Key="MaximumTabWidth">
        220
    </sys:Double>

    <!-- ========================================= -->
    <!-- CORNER RADII -->
    <!-- ========================================= -->

    <CornerRadius x:Key="RadiusSmall">
        4
    </CornerRadius>

    <CornerRadius x:Key="RadiusMedium">
        6
    </CornerRadius>

    <CornerRadius x:Key="RadiusLarge">
        8
    </CornerRadius>

</ResourceDictionary>
