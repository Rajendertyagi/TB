<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========================================= -->
    <!-- CORE SPACING SCALE -->
    <!-- ========================================= -->

    <sys:Double x:Key="Spacing0">
        0
    </sys:Double>

    <sys:Double x:Key="Spacing2">
        2
    </sys:Double>

    <sys:Double x:Key="Spacing4">
        4
    </sys:Double>

    <sys:Double x:Key="Spacing6">
        6
    </sys:Double>

    <sys:Double x:Key="Spacing8">
        8
    </sys:Double>

    <sys:Double x:Key="Spacing12">
        12
    </sys:Double>

    <sys:Double x:Key="Spacing16">
        16
    </sys:Double>

    <sys:Double x:Key="Spacing20">
        20
    </sys:Double>

    <sys:Double x:Key="Spacing24">
        24
    </sys:Double>

    <!-- ========================================= -->
    <!-- PADDING -->
    <!-- ========================================= -->

    <Thickness x:Key="PaddingTiny">
        2
    </Thickness>

    <Thickness x:Key="PaddingSmall">
        4
    </Thickness>

    <Thickness x:Key="PaddingMedium">
        6
    </Thickness>

    <Thickness x:Key="PaddingLarge">
        8
    </Thickness>

    <!-- ========================================= -->
    <!-- CONTROL PADDING -->
    <!-- ========================================= -->

    <Thickness x:Key="OmniboxPadding">
        10,0
    </Thickness>

    <Thickness x:Key="TabPadding">
        10,0,8,0
    </Thickness>

    <Thickness x:Key="StatusBarPadding">
        8,0
    </Thickness>

    <!-- ========================================= -->
    <!-- CONTROL MARGINS -->
    <!-- ========================================= -->

    <Thickness x:Key="ToolbarButtonMargin">
        0,0,2,0
    </Thickness>

    <Thickness x:Key="TabMargin">
        0,0,4,0
    </Thickness>

    <Thickness x:Key="StatusIconMargin">
        0,0,4,0
    </Thickness>

    <!-- ========================================= -->
    <!-- SHELL -->
    <!-- ========================================= -->

    <Thickness x:Key="ShellHorizontalMargin">
        8,0
    </Thickness>

    <Thickness x:Key="CompactControlMargin">
        4,0
    </Thickness>

    <!-- ========================================= -->
    <!-- CONTROL SIZES -->
    <!-- ========================================= -->

    <sys:Double x:Key="CompactButtonSize">
        28
    </sys:Double>

    <sys:Double x:Key="StatusButtonSize">
        22
    </sys:Double>

    <sys:Double x:Key="TabHeight">
        26
    </sys:Double>

</ResourceDictionary>
