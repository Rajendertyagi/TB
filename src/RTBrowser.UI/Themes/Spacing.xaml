<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================= -->
    <!-- CORE SPACING SCALE -->
    <!-- ========================================= -->

    <x:Double x:Key="Spacing0">
        0
    </x:Double>

    <x:Double x:Key="Spacing2">
        2
    </x:Double>

    <x:Double x:Key="Spacing4">
        4
    </x:Double>

    <x:Double x:Key="Spacing6">
        6
    </x:Double>

    <x:Double x:Key="Spacing8">
        8
    </x:Double>

    <x:Double x:Key="Spacing12">
        12
    </x:Double>

    <x:Double x:Key="Spacing16">
        16
    </x:Double>

    <x:Double x:Key="Spacing20">
        20
    </x:Double>

    <x:Double x:Key="Spacing24">
        24
    </x:Double>

    <!-- ========================================= -->
    <!-- STANDARD THICKNESS -->
    <!-- ========================================= -->

    <Thickness x:Key="PaddingTiny">
        2
    </Thickness>

    <Thickness x:Key="PaddingSmall">
        4
    </Thickness>

    <Thickness x:Key="PaddingMedium">
        6
    </Thickness>

    <Thickness x:Key="PaddingLarge">
        8
    </Thickness>

    <!-- ========================================= -->
    <!-- CONTROL PADDINGS -->
    <!-- ========================================= -->

    <Thickness x:Key="ToolbarButtonPadding">
        0
    </Thickness>

    <Thickness x:Key="OmniboxPadding">
        10,0
    </Thickness>

    <Thickness x:Key="TabPadding">
        10,0,8,0
    </Thickness>

    <Thickness x:Key="StatusBarPadding">
        8,0
    </Thickness>

    <!-- ========================================= -->
    <!-- CONTROL MARGINS -->
    <!-- ========================================= -->

    <Thickness x:Key="ToolbarButtonMargin">
        0,0,2,0
    </Thickness>

    <Thickness x:Key="TabMargin">
        0,0,4,0
    </Thickness>

    <Thickness x:Key="StatusIconMargin">
        0,0,4,0
    </Thickness>

    <!-- ========================================= -->
    <!-- LAYOUT SPACING -->
    <!-- ========================================= -->

    <Thickness x:Key="ShellHorizontalMargin">
        8,0
    </Thickness>

    <Thickness x:Key="CompactControlMargin">
        4,0
    </Thickness>

    <!-- ========================================= -->
    <!-- COMPACT SIZE TOKENS -->
    <!-- ========================================= -->

    <x:Double x:Key="CompactButtonSize">
        28
    </x:Double>

    <x:Double x:Key="StatusButtonSize">
        22
    </x:Double>

    <x:Double x:Key="TabHeight">
        26
    </x:Double>

</ResourceDictionary>
