<Window
    x:Class="TradingBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TradingBrowser.ViewModels"
    xmlns:controls="using:TradingBrowser.Controls"
    xmlns:services="using:TradingBrowser.Services"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    mc:Ignorable="d"
    Title="TradingBrowser">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <SplitView x:Name="MainSplitView" DisplayMode="Overlay" PaneBackground="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" CompactPaneLength="0" OpenPaneLength="350">
        <SplitView.Pane>
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Pivot Title="Library" Margin="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <PivotItem Header="Bookmarks">
                        <ListView x:Name="BookmarkListView" SelectionMode="Single" SelectionChanged="BookmarkListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="5">
                                        <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Url}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>
                    <PivotItem Header="History">
                        <ListView x:Name="HistoryListView" SelectionMode="Single" SelectionChanged="HistoryListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Padding="5">
                                        <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding VisitTime}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="10"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>
                </Pivot>
            </Border>
        </SplitView.Pane>
        
        <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" UseLayoutRounding="True">
            <Grid.Resources>
                <Style x:Key="EdgeToolbarButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Width" Value="32"/>
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="CornerRadius" Value="4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Grid x:Name="ButtonRootGrid" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal"/>
                                            <VisualState x:Name="PointerOver">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRootGrid" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Pressed">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ButtonRootGrid" Storyboard.TargetProperty="Background">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="0.4"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> 
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: Tab Strip -->
            <Grid Grid.Row="0" x:Name="AppTitleBar" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" MinHeight="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ✅ FIX: ListView constrained to allow horizontal scrolling -->
                <ListView x:Name="TabListView" Grid.Column="0"
                          ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                          SelectionChanged="TabListView_SelectionChanged"
                          SelectionMode="Extended"
                          CanReorderItems="True" AllowDrop="True"
                          ScrollViewer.HorizontalScrollMode="Enabled" 
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          Background="Transparent" Padding="4,0"
                          MinHeight="40" HorizontalAlignment="Left">
                    
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <!-- ✅ FIX: Hardcoded Edge-style fixed width -->
                            <Setter Property="Width" Value="240"/>
                            <Setter Property="MinWidth" Value="240"/>
                            <Setter Property="MaxWidth" Value="240"/>
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Grid Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TabViewModel">
                            <controls:TabItemPresenter 
                                Title="{x:Bind Title, Mode=OneWay}"
                                IsActive="{x:Bind IsActive, Mode=OneWay}"
                                CloseClicked="Tab_CloseClicked"
                                CloseTabRequested="Tab_CloseRequested"
                                CloseOtherTabsRequested="Tab_CloseOthersRequested"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Column="1" Click="NewTab_Click" 
                        Style="{StaticResource EdgeToolbarButtonStyle}"
                        VerticalAlignment="Center" Margin="4,0,8,0" ToolTipService.ToolTip="New Tab (Ctrl+T)">
                    <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </Button>
            </Grid>

            <!-- ROW 1: Toolbar & Omnibox -->
            <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button Click="Home_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Home">
                            <FontIcon Glyph="&#xE80F;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="BackButton" Click="Back_Click" Style="{StaticResource EdgeToolbarButtonStyle}" IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" ToolTipService.ToolTip="Back">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="ForwardButton" Click="Forward_Click" Style="{StaticResource EdgeToolbarButtonStyle}" IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}" ToolTipService.ToolTip="Forward">
                            <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button Click="Reload_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Reload">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                    </StackPanel>

                    <Border x:Name="OmniboxBorder" Grid.Column="2" 
                            Background="{ThemeResource ControlFillColorDefaultBrush}" 
                            CornerRadius="6" 
                            VerticalAlignment="Center" 
                            BorderThickness="1" 
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                        <Grid Padding="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <FontIcon x:Name="OmniboxIcon" Grid.Column="0" 
                                      Glyph="&#xE721;" 
                                      FontSize="14" 
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"/>
                            
                            <TextBox x:Name="Omnibox" Grid.Column="1"
                                     Text="{x:Bind ViewModel.OmniboxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     PlaceholderText="Search Google or type a URL"
                                     PlaceholderForeground="{ThemeResource TextFillColorTertiaryBrush}"
                                     KeyDown="Omnibox_KeyDown"
                                     Background="Transparent" 
                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                     BorderThickness="0"
                                     VerticalAlignment="Center" 
                                     VerticalContentAlignment="Center" 
                                     Padding="0,5,0,0" 
                                     FontSize="14"
                                     FontFamily="Segoe UI Variable"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button Click="SplitPane_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Split Right">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button x:Name="BookmarkButton" Click="Bookmark_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Bookmark (Ctrl+D)">
                            <FontIcon x:Name="BookmarkIcon" Glyph="&#xE734;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        
                        <Button Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Downloads">
                            <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Flyout.SystemBackdrop>
                                        <DesktopAcrylicBackdrop/>
                                    </Flyout.SystemBackdrop>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12">
                                        <Grid Width="350" MaxHeight="400">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Downloads" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                                            <ListView Grid.Row="1" ItemsSource="{x:Bind DownloadManager.ActiveDownloads, Mode=OneWay}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="services:ActiveDownload">
                                                        <Grid Padding="8" RowSpacing="6" Margin="0,4">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                                            <ProgressBar Grid.Row="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" Height="4" CornerRadius="2"/>
                                                            <Grid Grid.Row="2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.ColumnSpacing>8</Grid.ColumnSpacing>
                                                                
                                                                <TextBlock Text="{x:Bind StatusText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1" Command="{x:Bind PauseCommand}" Visibility="{x:Bind PauseVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Pause">
                                                                    <FontIcon Glyph="&#xE769;" FontSize="12"/>
                                                                </Button>
                                                                <Button Grid.Column="2" Command="{x:Bind ResumeCommand}" Visibility="{x:Bind ResumeVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Resume">
                                                                    <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                                                </Button>
                                                                <Button Grid.Column="3" Command="{x:Bind CancelCommand}" Visibility="{x:Bind CancelVisibility, Mode=OneWay}" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Cancel">
                                                                    <FontIcon Glyph="&#xE711;" FontSize="12"/>
                                                                </Button>
                                                            </Grid>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <Button Click="Settings_Click" Style="{StaticResource EdgeToolbarButtonStyle}" ToolTipService.ToolTip="Settings">
                            <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ROW 2: Flexible Tiling Host -->
            <Grid Grid.Row="2" x:Name="TilingHost" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <WebView2 x:Name="MainWebView" Grid.Row="0" Grid.Column="0" DefaultBackgroundColor="Transparent"/>
                <WebView2 x:Name="SecondaryWebView" Visibility="Collapsed" DefaultBackgroundColor="Transparent"/>
                
                <primitives:Thumb x:Name="TilingDivider" Visibility="Collapsed" DragDelta="TilingDivider_DragDelta" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <Border x:Name="TilingHeader" Visibility="Collapsed" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8" Padding="4" CornerRadius="6" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Click="SwitchToHorizontal_Click" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Horizontal">
                            <FontIcon Glyph="&#xE8A5;" FontSize="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button Click="SwitchToVertical_Click" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Vertical">
                            <FontIcon Glyph="&#xE8A6;" FontSize="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button Click="SwitchToGrid_Click" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Grid">
                            <FontIcon Glyph="&#xE8A7;" FontSize="10" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Button>
                        <Button Click="Untile_Click" Width="24" Height="24" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Untile">
                            <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </SplitView>
</Window>
