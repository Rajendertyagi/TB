<UserControl
    x:Class="TradingBrowser.Controls.TabItemPresenter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="36" Width="240">

    <Grid x:Name="RootGrid" Background="Transparent" IsHitTestVisible="True"
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited">
        
        <!-- ✅ FIX: Native ContextFlyout forces the OS to yield the right-click and blocks the Move/Size menu -->
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Text="Close tab" Click="CloseTab_Click"/>
                <MenuFlyoutItem Text="Close other tabs" Click="CloseOtherTabs_Click"/>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <!-- Inactive Background (Visible by default) -->
        <Rectangle x:Name="InactiveBackground" Fill="Transparent" Stroke="Transparent" StrokeThickness="1" RadiusX="8" RadiusY="8" Margin="0,4,0,0" Visibility="Visible"/>
        
        <!-- Active Background (Hidden by default, uses ThemeResource so it updates with Light/Dark mode) -->
        <Rectangle x:Name="ActiveBackground" Fill="{ThemeResource LayerFillColorDefaultBrush}" Stroke="{ThemeResource CardStrokeColorDefaultBrush}" StrokeThickness="1" RadiusX="8" RadiusY="8" Margin="0,4,0,0" Visibility="Collapsed"/>
        
        <!-- Bottom Cover: Hides toolbar border when active -->
        <Rectangle x:Name="BottomCover" Fill="{ThemeResource LayerFillColorDefaultBrush}" Height="2" VerticalAlignment="Bottom" Visibility="Collapsed" Margin="0,0,0,-2"/>

        <Grid Padding="12,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{x:Bind Title, Mode=OneWay}" 
                       VerticalAlignment="Center" FontSize="12" 
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="1" x:Name="CloseButton" Click="CloseButton_Click" 
                    Width="20" Height="20" MinWidth="20" MinHeight="20" 
                    Padding="0" CornerRadius="4" Background="Transparent" BorderThickness="0"
                    VerticalAlignment="Center" Visibility="Collapsed">
                <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
