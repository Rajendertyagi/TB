<Window
    x:Class="TB.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:TB.Models"
    mc:Ignorable="d">

    <Grid Background="#FF1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="#FF151515">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="TabStrip"
                      ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.CurrentTab, Mode=TwoWay}"
                      SelectionChanged="TabStrip_SelectionChanged"
                      Grid.Column="0"
                      BorderThickness="0"
                      Padding="10,4,0,0"
                      Background="Transparent">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="2"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:TabState">
                        <Grid Background="{Binding IsActive, Converter={StaticResource BooleanToColorConverter}, FallbackValue=#FF2D2D2D}" 
                              CornerRadius="8,8,0,0" 
                              Padding="16,6,8,6" 
                              MinWidth="140" 
                              MaxWidth="220">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" 
                                       Foreground="White" 
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"/>
                            
                            <Button Grid.Column="1" 
                                    Content="✕" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Foreground="#FFA0A0A0"
                                    FontSize="10"
                                    Margin="8,0,0,0"
                                    Padding="4,2,4,2"
                                    Click="CloseTab_Click"
                                    DataContext="{x:Bind}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Grid.Column="1" 
                    Command="{x:Bind ViewModel.CreateTabCommand}"
                    Content="＋" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="White" 
                    Width="40" 
                    Height="40" 
                    VerticalAlignment="Bottom"
                    Margin="0,0,140,4"/>
        </Grid>

        <Grid Grid.Row="1" Background="#FF252525" Padding="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="White" Width="36" Click="GoBack_Click"/>
            <Button Grid.Column="1" Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="White" Width="36" Click="GoForward_Click"/>
            <Button Grid.Column="2" Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="White" Width="36" Click="Refresh_Click" Margin="0,0,8,0"/>

            <TextBox Grid.Column="3" 
                     x:Name="Omnibox"
                     Text="{x:Bind ViewModel.OmniboxText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="Omnibox_KeyDown"
                     Background="#FF1E1E1E" 
                     Foreground="White" 
                     BorderBrush="#FF3D3D3D"
                     PlaceholderText="Search or enter web address" 
                     VerticalAlignment="Center"/>
        </Grid>

        <WebView2 x:Name="SharedWebView" 
                  Grid.Row="2" 
                  CoreWebView2Initialized="SharedWebView_CoreWebView2Initialized"
                  NavigationCompleted="SharedWebView_NavigationCompleted"
                  Source="about:blank"/>
    </Grid>
</Window>
