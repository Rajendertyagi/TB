<UserControl x:Class="TB.UI.Controls.TabStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="{StaticResource TBToolbarMargin}">

        <Button Width="40"
                Style="{StaticResource TBButtonStyle}"
                Content="+"
                Command="{Binding AddTabCommand}" />

        <ListBox Margin="8,0,0,0"
                 Height="28"
                 BorderThickness="0"
                 ItemsSource="{Binding Tabs}"
                 SelectedItem="{Binding ActiveTab, Mode=TwoWay}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>

                    <Border Margin="{StaticResource TBTabMargin}"
                            Padding="{StaticResource TBTabPadding}"
                            BorderThickness="1">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Title}" />

                            <Button Width="20"
                                    Margin="{StaticResource TBTabCloseButtonMargin}"
                                    Style="{StaticResource TBButtonStyle}"
                                    Content="×"
                                    Command="{Binding DataContext.CloseTabCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />

                        </StackPanel>

                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </DockPanel>

</UserControl>