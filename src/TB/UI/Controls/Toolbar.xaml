<UserControl x:Class="TB.UI.Controls.Toolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource TBBackgroundBrush}">

    <Grid Background="{StaticResource TBBackgroundBrush}"
          Margin="{StaticResource TBToolbarMargin}">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="Auto"/>

            <ColumnDefinition Width="Auto"/>

            <ColumnDefinition Width="Auto"/>

            <ColumnDefinition Width="*"/>

            <ColumnDefinition Width="Auto"/>

        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Width="40"
                Style="{StaticResource TBButtonStyle}"
                Content="←"
                Command="{Binding BackCommand}" />

        <Button Grid.Column="1"
                Width="40"
                Margin="{StaticResource TBToolbarControlSpacing}"
                Style="{StaticResource TBButtonStyle}"
                Content="→"
                Command="{Binding ForwardCommand}" />

        <Button Grid.Column="2"
                Width="40"
                Margin="{StaticResource TBToolbarControlSpacing}"
                Style="{StaticResource TBButtonStyle}"
                Content="⟳"
                Command="{Binding RefreshCommand}" />

        <TextBox x:Name="AddressBar"
                 Grid.Column="3"
                 Style="{StaticResource TBTextBoxStyle}"
                 Margin="{StaticResource TBAddressBarMargin}"
                 VerticalContentAlignment="Center"
                 Text="{Binding Address,
                                UpdateSourceTrigger=PropertyChanged}" />

        <Button x:Name="GoButton"
                Grid.Column="4"
                Width="80"
                Style="{StaticResource TBButtonStyle}"
                Content="Go"
                Command="{Binding NavigateCommand}" />

    </Grid>

</UserControl>
