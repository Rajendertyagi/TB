<Application x:Class="TB.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>

        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary
                    Source="UI/Resources/TBFonts.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBColors.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBWindow.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBButtons.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBWindowButtons.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBTextBox.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBToolbar.xaml" />

                <ResourceDictionary
                    Source="UI/Resources/TBTabs.xaml" />

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>