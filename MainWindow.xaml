<Window x:Class="ModernWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Enterprise Web Application Container" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- The modern Chromium-based WebView2 instance -->
        <wv2:WebView2 x:Name="MainWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</Window>
