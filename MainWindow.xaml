<Window
    x:Class="MinimalBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Minimal Browser"
    Width="1200"
    Height="800">
    
    <Grid Background="#202124">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="8,8,8,8" Background="#292a2d" Spacing="8">
            <Button x:Name="BackButton" Content="←" Width="40" Height="32" Click="BackButton_Click" Background="#3c4043" Foreground="#e8eaed" BorderThickness="0"/>
            <Button x:Name="ForwardButton" Content="→" Width="40" Height="32" Click="ForwardButton_Click" Background="#3c4043" Foreground="#e8eaed" BorderThickness="0"/>
            <Button x:Name="RefreshButton" Content="⟳" Width="40" Height="32" Click="RefreshButton_Click" Background="#3c4043" Foreground="#e8eaed" BorderThickness="0"/>
            <TextBox x:Name="AddressBar" Width="800" Height="32" PlaceholderText="Search or enter address" KeyDown="AddressBar_KeyDown" Background="#35363a" Foreground="#e8eaed" BorderThickness="0"/>
            <Button x:Name="GoButton" Content="Go" Width="60" Height="32" Click="GoButton_Click" Background="#5f6368" Foreground="#e8eaed" BorderThickness="0"/>
        </StackPanel>

        <!-- WebView2 -->
        <WebView2 x:Name="webView" Grid.Row="1"/>
    </Grid>
</Window>
