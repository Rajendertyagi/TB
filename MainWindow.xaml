<Window
    x:Class="TB.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TB"
    Title="TB Browser"
    ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="10" Spacing="5">
            <Button Content="&#xE72B;" FontFamily="Segoe Fluent Icons" Click="Back_Click"/>
            <Button Content="&#xE72A;" FontFamily="Segoe Fluent Icons" Click="Forward_Click"/>
            <Button Content="&#xE72C;" FontFamily="Segoe Fluent Icons" Click="Refresh_Click"/>
            <TextBox x:Name="UrlTextBox" Width="400" PlaceholderText="Enter URL..." KeyDown="UrlTextBox_KeyDown"/>
            <Button Content="Go" Click="Go_Click"/>
        </StackPanel>

        <TabView Grid.Row="1" 
                 x:Name="BrowserTabs" 
                 TabItemsSource="{x:Bind ViewModel.Tabs}"
                 TabCloseRequested="BrowserTabs_TabCloseRequested"
                 AddTabButtonClick="BrowserTabs_AddTabButtonClick">
            <TabView.TabItemTemplate>
                <DataTemplate x:DataType="local:BrowserTab">
                    <TabViewItem Header="{x:Bind Title}" IconSource="{x:Bind Icon}"/>
                </DataTemplate>
            </TabView.TabItemTemplate>
        </TabView>
    </Grid>
</Window>
