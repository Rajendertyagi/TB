<Window
    x:Class="TradingBrowser.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TradingBrowser"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="#1A1A1A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,8,0">
                <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="#00E676" FontFamily="Segoe MDL2 Assets"/>
                <TextBlock Text="TB" FontWeight="Bold" Foreground="#FFFFFF" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TabView x:Name="MainTabs" Grid.Column="1" VerticalAlignment="Bottom" 
                     TabItemsSource="{x:Bind ViewModel.OpenTabs, Mode=OneWay}"
                     SelectedItem="{x:Bind ViewModel.ActiveTab, Mode=TwoWay}"
                     AddTabButtonCommand="{x:Bind ViewModel.OpenNewTabCommand}"
                     Background="Transparent">
                <TabView.TabItemTemplate>
                    <DataTemplate x:DataType="local/TabContext">
                        <TabViewItem Header="{x:Bind Title, Mode=OneWay}">
                            <TabViewItem.IconSource>
                                <SymbolIconSource Symbol="Globe"/>
                            </TabViewItem.IconSource>
                        </TabViewItem>
                    </DataTemplate>
                </TabView.TabItemTemplate>
            </TabView>
        </Grid>

        <Grid Grid.Row="1" Background="#252526" Padding="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,0,8,0">
                <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#FFFFFF" Width="36" Height="32"/>
                <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#FFFFFF" Width="36" Height="32"/>
                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#FFFFFF" Width="36" Height="32"/>
            </StackPanel>

            <AutoSuggestBox x:Name="Omnibox" Grid.Column="1" 
                            Text="{x:Bind ViewModel.ActiveTab.CurrentUrl, Mode=OneWay}"
                            PlaceholderText="Search or enter web address..." 
                            QueryIcon="Find" Background="#1E1E1E" Foreground="#FFFFFF" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#FFFFFF" Width="36" Height="32"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="BrowserGrid" Grid.Row="2" Background="#121212">
            </Grid>
    </Grid>
</Window>
