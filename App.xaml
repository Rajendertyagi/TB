<Application
    x:Class="TradingBrowser.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <MenuFlyout x:Key="TabContextMenu">
                <MenuFlyoutItem Text="New Tab" Icon="Add"/>
                <MenuFlyoutItem Text="Duplicate Tab" Icon="Copy"/>
                <MenuFlyoutItem Text="Pin Tab" Icon="Pin"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Close Tab" Icon="Cancel"/>
                <MenuFlyoutItem Text="Close Other Tabs"/>
                <MenuFlyoutItem Text="Reopen Closed Tab"/>
            </MenuFlyout>
        </ResourceDictionary>
    </Application.Resources>
</Application>
